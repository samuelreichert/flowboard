{
  "name": "flowboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.8.1",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@base-ui/react": "^1.5.0",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@tiptap/extension-file-handler": "^3.25.0",
    "@tiptap/extension-image": "^3.25.0",
    "@tiptap/extension-list": "^3.25.0",
    "@tiptap/extension-text-align": "^3.25.0",
    "@tiptap/markdown": "^3.25.0",
    "@tiptap/pm": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "scripts": {
    "dev": "npm run build:server && VITE_BOARD_API_URL=/api/board node dist-server/server/index.js --dev",
    "dev:static": "vite",
    "start": "npm run build:server && node dist-server/server/index.js",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:local": "VITE_BOARD_API_URL=/api/board npm run build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "doctor": "npx react-doctor@latest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "browserslist": [
    "defaults",
    "not dead",
    "not op_mini all"
  ],
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
