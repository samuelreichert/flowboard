{
  "name": "flowboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.8.1",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@base-ui/react": "^1.5.0",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-query": "^5.101.2",
    "@tiptap/extension-file-handler": "^3.25.0",
    "@tiptap/extension-image": "^3.25.0",
    "@tiptap/extension-list": "^3.25.0",
    "@tiptap/extension-text-align": "^3.25.0",
    "@tiptap/markdown": "^3.25.0",
    "@tiptap/pm": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.17.0",
    "pg": "^8.22.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^8.2.0"
  },
  "scripts": {
    "dev": "npm run build:server && node --env-file=.env dist-server/server/index.js --dev",
    "dev:static": "vite",
    "start": "npm run build:server && node dist-server/server/index.js",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:local": "npm run build",
    "db:generate": "npm run db:generate:sqlite && npm run db:generate:postgres",
    "db:generate:sqlite": "PRISMA_PROVIDER=sqlite prisma generate",
    "db:generate:postgres": "PRISMA_PROVIDER=postgresql prisma generate",
    "db:ensure:sqlite": "node scripts/ensure-sqlite-database.mjs",
    "db:migrate:sqlite": "npm run db:ensure:sqlite && PRISMA_PROVIDER=sqlite prisma migrate dev",
    "db:migrate:postgres": "PRISMA_PROVIDER=postgresql prisma migrate dev",
    "db:deploy:postgres": "PRISMA_PROVIDER=postgresql prisma migrate deploy",
    "db:reset:sqlite": "PRISMA_PROVIDER=sqlite prisma migrate reset",
    "db:studio:sqlite": "PRISMA_PROVIDER=sqlite prisma studio",
    "db:studio:postgres": "PRISMA_PROVIDER=postgresql prisma studio",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:diagnostics": "tsc -b --extendedDiagnostics",
    "benchmark:ts": "node scripts/benchmark-typescript.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "doctor": "npx react-doctor@latest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "browserslist": [
    "defaults",
    "not dead",
    "not op_mini all"
  ],
  "overrides": {
    "undici": "7.28.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
