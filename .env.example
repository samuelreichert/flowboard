# Local Prisma/SQLite development
PRISMA_PROVIDER=sqlite
DATABASE_URL=file:./data/flowboard.local.db

# Supabase Auth client values. These are public browser values.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key

# Server-side Supabase verification. Keep service-role and database secrets off the client.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key

# Public social auth feature flags. Google defaults on unless set to false.
VITE_SUPABASE_GOOGLE_OAUTH_ENABLED=true
VITE_SUPABASE_APPLE_OAUTH_ENABLED=false

# Production Prisma/Postgres. Use with PRISMA_PROVIDER=postgresql.
# DATABASE_URL=postgresql://postgres.project-ref:password@region.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.project-ref:password@region.pooler.supabase.com:5432/postgres
