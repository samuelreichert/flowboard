# Database
DATABASE_URL=file:./data/flowboard.local.db
# DIRECT_URL=

# Local server
# PORT=5173
# Enables no-auth SQLite board access for built local server smoke tests.
# Ignored when PRISMA_PROVIDER=postgresql.
# FLOWBOARD_LOCAL_DEV_AUTH=true

PRISMA_PROVIDER=sqlite

# Server-side Supabase configuration
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=

# Optional authenticated API origin override
# VITE_FLOWBOARD_API_URL=

# Browser Supabase configuration
VITE_SUPABASE_APPLE_OAUTH_ENABLED=false
VITE_SUPABASE_AVATAR_BUCKET=flowboard-profile-avatars
VITE_SUPABASE_GOOGLE_OAUTH_ENABLED=false
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
